# ─────────────────────────────────────────────
# APIMatic Doc Search — Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values

# Groq API Key (get free key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Groq Model (free tier)
GROQ_MODEL=qwen/qwen3-32b

# LLM Parameters
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.3

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# APIMatic Docs Repository (update with your actual repo URL)
APIMATIC_DOCS_REPO=https://github.com/apimatic/apimatic-docs.git

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
